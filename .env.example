TELEGRAM_BOT_TOKEN=INSERISCI_TOKEN_REALE
LOG_LEVEL=INFO
BOT_DATA_DIR=/data

# ID Telegram dell'admin (trovalo con @userinfobot su Telegram).
# Per più admin separare con virgola: ADMIN_TELEGRAM_ID=111111,222222
ADMIN_TELEGRAM_ID=

# Solo per docker-compose.image.yml (deploy da immagine GHCR già buildata)
GITHUB_USERNAME=tuo-username-github
